#!/bin/bash
####################################################################################################
# @file     PowerBash
# @brief    Installer script for powerbash configurations.
#
# @author   sheer.rey<sheer.rey@gmail.com>
# @date     03/07/2025
# @version  0.0.1
####################################################################################################

# root directory of PowerBash project
powerbash_root="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"

# load predefined variables and functions
if [ -f "${powerbash_root}/HOME/.nicetools/predefined" ]; then
    source "${powerbash_root}/HOME/.nicetools/predefined"
else
    echo "Error: predefined file not found!" 1>&2
    exit 1
fi

# current time for backup suffix
current_time=$(date +"%Y%m%d%H%M%S")

# source statement
bashrc_file="$HOME/.bashrc"
source_comment_begin='# POWERBASH BEGIN, DO NOT MODIFY THIS BLOCK!'
source_comment_end='# POWERBASH END, DO NOT MODIFY THIS BLOCK!'

# predefined variables
install_path=
uninstall_path=
install_archive=
install_force=0
enable_ssh_tunnel_service=0
ssh_tunnel_service_file="ssh-tunnel.service"
ssh_tunnel_script_file="CreateSSHTunnel"
backup_dir=".PowerBashBackup"
backup_prefix="powerbash-"
backup_suffix=".tar.gz"
backup_file="$backup_prefix$current_time$backup_suffix"
backup_pattern='^powerbash-[0-9]+\.tar\.gz$'
files=(
    ".powerbashrc"
    ".vimrc"
    ".gitconfig"
    ".gitignore"
    ".gitmessage"
    ".tmux.conf"
    ".clang-format"
)
dirs=(
    ".vim"
    ".config/clangd"
    ".nicetools"
)
dependencies=(
    "vim"          # configuration required
    "tmux"         # configuration required
    "ack"          # may used by vim plugin 'ack.vim'
    "ag"           # may used by vim plugin 'ack.vim'
    "ctags"        # may used by vim built-in jump and auto completion
    "cscope"       # may used by vim built-in jump and auto completion
    "global"       # may used by vim plugin 'gutentags'
    "gtags"        # may used by vim plugin 'gutentags'
    "gtags-cscope" # may used by vim plugin 'gutentags'
    "rg"           # may used by vim plugin 'leaderf'
    "cppman"       # may used by vim plugin 'vim-cppman'
    "python3"      # may used by multiple vim plugins
    "git"          # may used by multiple vim plugins
)

# predefined options for PowerBash
sopt="hfi::u::a:"
lopt="help,force,install::,uninstall::,archive:,enable-ssh-tunnel-service"

# predefined functions for PowerBash
function PrintHelp {
    cat <<!
Usage: $(basename "${BASH_SOURCE[0]}") [option] ...
Used for PowerBash package management(install, uninstall, etc.).

Options:
  -i, --install [path]      Install PowerBash package into specified [path].
                            If it has been already installed in specified path,
                            previous package files will archived to file with
                            prefix '$backup_prefix' in '[path]/$backup_dir'.
                            If [path] has not been specified, install to \$HOME
                            by default.
  -u, --uninstall [path]    Uninstall PowerBash package from specified [path].
                            If [path] has not been specified, uninstall from
                            \$HOME by default.
  -a, --archive <file>      Only valid with -i/--install option. Used to install
                            PowerBash package with the specified archived backup
                            <file> instead of original one.
      --enable-ssh-tunnel-service
                            Only valid with -i/--install option. Enable SSH tunnel
                            systemd service installation. If this option has been
                            specified, it will prompt for necessary information for
                            ssh tunnel service configuration.
  -f, --force               Only valid with -i/--install option. Used to overwrite
                            existing PowerBash package files instead of archive.

  -h, --help                Print this help message and exit.

Environment Variables:
  POWERBASH_ADD_BIN_PATH    If set to 1, the script will add the specified path to
                            the PATH environment variable. This is useful for adding
                            custom binary directories to your shell's PATH.
!
}

function PrintHelpCompatible {
    cat <<!
Usage: $(basename "${BASH_SOURCE[0]}") [option] ...
Used for PowerBash package management(install, uninstall, etc.).

Options:
  -i [path]     Install PowerBash package into specified [path]. If it has been
                already installed in specified path, previous package files will
                archived to file with prefix '$backup_prefix' in '[path]/$backup_dir'.
                If [path] has not been specified, install to \$HOME by default.
  -u [path]     Uninstall PowerBash package from specified [path].
                If [path] has not been specified, uninstall from \$HOME by default.
  -a <file>     Only valid with -i/--install option. Used to install PowerBash
                package with the specified archived backup <file> instead of
                original one.
  -f            Only valid with -i option. Used to overwrite existing PowerBash
                package files instead of archive.

  -h            Print this help message and exit.

Environment Variables:
  POWERBASH_ADD_BIN_PATH    If set to 1, the script will add the specified path to
                            the PATH environment variable. This is useful for adding
                            custom binary directories to your shell's PATH.
!
}

function ConfigureGit {
    local git_cfg_file="$install_path/.gitconfig"

    # Only configure git user information when .gitconfig file exist, otherwise skip it directly
    if [ -f "$git_cfg_file" ]; then
        PrintInfo "${font_magenta}Configuring git user information ...${font_reset}"
        local prompt="Please enter your git user name: "
        read -erp "${prompt}" git_user_name
        local prompt="Please enter your git user email: "
        read -erp "${prompt}" git_user_email

        if [ -n "$git_user_name" ] && [ -n "$git_user_email" ]; then
            git config --file "$git_cfg_file" user.name "$git_user_name"
            git config --file "$git_cfg_file" user.email "$git_user_email"
            PrintInfo "${font_green}Git user information configured successfully!${font_reset}"
        else
            PrintWarning "Git user information not configured!"
        fi
    fi
}

function ConfigureSSHTunnelService {
    # Check the existence of ssh tunnel service file and script file in installation path
    local service_file
    service_file=$(find "$install_path" -type f -name "$ssh_tunnel_service_file" 2>/dev/null \
                   | head -n 1)
    if [ -z "$service_file" ]; then
        PrintWarning "SSH tunnel service file '$ssh_tunnel_service_file' not found in " \
                     "installation path, skipping SSH tunnel service configuration!"
        return 0
    fi

    local script_file
    script_file=$(find "$install_path" -type f -name "$ssh_tunnel_script_file" 2>/dev/null \
                  | head -n 1)
    if [ -z "$script_file" ]; then
        PrintWarning "SSH tunnel script file '$ssh_tunnel_script_file' not found in " \
                     "installation path, skipping SSH tunnel service configuration!"
        return 0
    fi

    PrintInfo "${font_magenta}Configuring SSH tunnel service ...${font_reset}"

    # Get the actual username
    local actual_username
    actual_username=$(whoami)
    if [ "$actual_username" == "root" ]; then
        actual_username=$(logname 2>/dev/null || echo "root")
    fi

    # Prompt for host:port
    local ssh_tunnel_host_port
    local prompt="Please enter the target host and port for ssh tunnel (e.g. 10.65.46.222:8001): "
    read -erp "${prompt}" ssh_tunnel_host_port

    # Validate host:port format
    if [ -z "$ssh_tunnel_host_port" ]; then
        PrintWarning "SSH tunnel host:port not provided, skipping SSH tunnel service configuration!"
        return 0
    elif ! [[ "$ssh_tunnel_host_port" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}:[0-9]+$ ]]; then
        PrintWarning "Invalid host:port format '$ssh_tunnel_host_port', \
                      skipping SSH tunnel service configuration!"
        PrintWarning "Please use format as IP:PORT (e.g. 10.65.46.222:8001)"
        return 0
    fi

    # Prompt for user@ip or ssh profile
    local ssh_tunnel_jump_server
    local prompt="Please enter the user@ip or SSH profile name for ssh tunnel "
    local prompt+="(e.g. user@10.65.10.11 or My-Jump-Demo): "
    read -erp "${prompt}" ssh_tunnel_jump_server

    # Validate ssh tunnel jump server input
    if [ -z "$ssh_tunnel_jump_server" ]; then
        PrintWarning "SSH tunnel jump server not provided, " \
                     "skipping SSH tunnel service configuration!"
        return 0
    fi

    # Determine if input is user@ip or ssh profile
    local is_user_ip=0
    local is_ssh_profile=0
    if [[ "$ssh_tunnel_jump_server" =~ ^[^@]+@([0-9]{1,3}\.){3}[0-9]{1,3}(:[0-9]+)?$ ]]; then
        # Validate connectivity to user@ip
        if ! ssh -o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=no \
                 -o UserKnownHostsFile=/dev/null "$ssh_tunnel_jump_server" true &>/dev/null; then
            PrintWarning "Cannot connect to user@ip '$ssh_tunnel_jump_server', "\
                         "skipping SSH tunnel service configuration!"
            PrintWarning "Please verify the host is reachable!"
            return 0
        fi
        is_user_ip=1
    else
        # Validate existance and connectivity of SSH profile
        if [ ! -f "$HOME/.ssh/config" ]; then
            PrintWarning "SSH config file not found at '$HOME/.ssh/config', " \
                         "skipping SSH tunnel service configuration!"
            return 0
        elif ! grep -q "^Host \+${ssh_tunnel_jump_server}" "$HOME/.ssh/config"; then
            PrintWarning "SSH profile '$ssh_tunnel_jump_server' not found in " \
                         "'$HOME/.ssh/config', skipping SSH tunnel service configuration!"
            return 0
        elif ! ssh -o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=no \
                   -o UserKnownHostsFile=/dev/null "$ssh_tunnel_jump_server" true &>/dev/null; then
            PrintWarning "Cannot connect to SSH profile '$ssh_tunnel_jump_server', " \
                         "skipping SSH tunnel service configuration!"
            PrintWarning "Please verify the SSH profile is correct!"
            return 0
        fi
        is_ssh_profile=1
    fi

    # Replace placeholders in the service file
    local nicetools_bin_path
    nicetools_bin_path=$(dirname "$script_file")
    sed -i "s|{{NICETOOLS_BIN_PATH}}|$nicetools_bin_path|g" "$service_file"
    sed -i "s|{{USERNAME}}|$actual_username|g" "$service_file"
    sed -i "s|{{HOST}}:{{PORT}}|$ssh_tunnel_host_port|g" "$service_file"

    # Build script params based on input type
    if [ $is_user_ip -eq 1 ]; then
        sed -i "s|{{SCRIPT_PARAMS}}|$ssh_tunnel_jump_server|g" "$service_file"
        PrintDebug "${font_green}SSH tunnel service file configured with " \
                   "host:port=$ssh_tunnel_host_port and " \
                   "jump-server=$ssh_tunnel_jump_server!${font_reset}"
    elif [ $is_ssh_profile -eq 1 ]; then
        sed -i "s|{{SCRIPT_PARAMS}}|-P $ssh_tunnel_jump_server|g" "$service_file"
        PrintDebug "${font_green}SSH tunnel service file configured with " \
                   "host:port=$ssh_tunnel_host_port and " \
                   "jump-server=$ssh_tunnel_jump_server!${font_reset}"
    fi

    PrintInfo "${font_green}SSH tunnel service file configured successfully!${font_reset}"
}

function DoInstall {
    # authority check for $install_path
    PrintInfo "${font_magenta}Checking authority for installation directory ...${font_reset}"
    if ! [ -r "$install_path" ] || ! [ -w "$install_path" ] || ! [ -x "$install_path" ]; then
        PrintError "$install_path not accessble, install canceled!"
        exit 2
    fi

    # check and backup previous configuration
    if [ $install_force -ne 1 ]; then
        PrintInfo "${font_magenta}Checking authority for backup directory ...${font_reset}"
        if [ -e "$install_path/$backup_dir" ]; then
            if ! [ -d "$install_path/$backup_dir" ]; then
                PrintError "$install_path/$backup_dir existing but not a directory, " \
                           "install canceled!"
                exit 2
            elif ! [ -w "$install_path/$backup_dir" ]; then
                PrintError "$install_path/$backup_dir existing but not writeable, " \
                           "install canceled!"
                exit 2
            fi
        else
            mkdir -p "$install_path/$backup_dir"
        fi

        PrintInfo "${font_magenta}Looking for existing configurations ...${font_reset}"
        local temp_dir
        temp_dir=$(mktemp -d)
        for file in "${files[@]}"; do
            if [ -f "$install_path/$file" ]; then
                PrintInfo "${font_yellow}Found file $install_path/$file${font_reset}"
                mkdir -p "$(dirname "$temp_dir/$file")"
                cp "$install_path/$file" "$temp_dir/$file"
            fi
        done
        for dir in "${dirs[@]}"; do
            if [ -d "$install_path/$dir" ]; then
                PrintInfo "${font_yellow}Found directory $install_path/$dir${font_reset}"
                mkdir -p "$(dirname "$temp_dir/$dir")"
                cp -rf "$install_path/$dir" "$temp_dir/$dir"
            fi
        done

        if [ -z "$(ls -A "$temp_dir")" ]; then
            PrintInfo "${font_yellow}No existing configurations found${font_reset}"
        else
            PrintInfo "${font_magenta}%s%s${font_reset}" \
                      "Backing up existing configurations to " \
                      "$install_path/$backup_dir/$backup_file ..."
            tar -czf "$install_path/$backup_dir/$backup_file" -C "$temp_dir" "$(ls -A "$temp_dir")"
        fi
        rm -rf "$temp_dir"
    fi

    # extract PowerBash from $install_archive
    if [ -n "$install_archive" ]; then
        PrintInfo "${font_magenta}Checking authority for archive file ...${font_reset}"
        if ! [ -e "$install_archive" ]; then
            PrintError "specified archive file $install_archive not exist, install canceled!"
            exit 2
        fi
        if ! [ -r "$install_archive" ]; then
            PrintError "specified archive file $install_archive is not accessble, install canceled!"
            exit 2
        fi

        PrintInfo "${font_magenta}Checking validity for archive file ...${font_reset}"
        if ! [[ "$(basename "$install_archive")" =~ $backup_pattern ]] || \
           ! tar -tzf "$install_archive" &>/dev/null; then
            PrintError "specified archive file $install_archive is not valid, install canceled!"
            exit 2
        fi
        local temp_dir
        temp_dir=$(mktemp -d)
        tar -xzf "$install_archive" -C "$temp_dir" &>/dev/null
        for file in "${files[@]}"; do
            if [ -f "$temp_dir/$file" ]; then
                PrintDebug "found file $file in specified archive file $install_archive!"
            else
                PrintWarning "file $file not found in specified archive file $install_archive!"
            fi
        done
        for dir in "${dirs[@]}"; do
            if [ -d "$temp_dir/$dir" ]; then
                PrintDebug "found directory $dir in specified archive file $install_archive!"
            else
                PrintWarning "directory $dir not found in specified archive file $install_archive!"
            fi
        done
    fi

    # check dependent tools' existance
    for dep in "${dependencies[@]}"; do
        if ! which "$dep" &>/dev/null; then
            PrintWarning "%b%s" \
                         "missing ${font_yellow}$dep${font_reset} tool, " \
                         "there may be compatibility issues."
        fi
    done

    # install PowerBash configurations
    PrintInfo "${font_magenta}Start to install PowerBash ...${font_reset}"
    local powerbash_src_dir
    if [ -n "$install_archive" ]; then
        powerbash_src_dir="$temp_dir"
    else
        powerbash_src_dir="$powerbash_root/HOME"
    fi
    for file in "${files[@]}"; do
        if [ -e "$powerbash_src_dir/$file" ]; then
            PrintDebug "Installing file $file into $install_path ..."
            rm -f "$install_path/$file"
            mkdir -p "$(dirname "$install_path/$file")"
            cp -f "$powerbash_src_dir/$file" "$install_path/$file"
        fi
    done
    for dir in "${dirs[@]}"; do
        if [ -e "$powerbash_src_dir/$dir" ]; then
            PrintDebug "Installing directory $dir into $install_path ..."
            rm -rf "${install_path:?}/${dir:?}"
            mkdir -p "$(dirname "$install_path/$dir")"
            cp -rf "$powerbash_src_dir/$dir" "$install_path/$dir"
        fi
    done

    # find all bin directories in installed 'dirs', set execute permission for all files within bin
    # directories, and add each bin directory to PATH environment variable in .powerbashrc
    for dir in "${dirs[@]}"; do
        local bin_dir
        bin_dir=$(find "$install_path/$dir" -type d -name "bin" \
                        ! -path "$install_path/.vim/*" \
                        ! -path "$install_path/.config/*" \
                        2>/dev/null)
        if [ -n "$bin_dir" ]; then
            for bin_path in $bin_dir; do
                chmod -R +x "$bin_path"
                if [[ -n "${POWERBASH_ADD_BIN_PATH:-}" && "$POWERBASH_ADD_BIN_PATH" == "1" ]]; then
                    PrintInfo "${font_magenta}Adding $bin_path to PATH environment variable " \
                              "in .powerbashrc ...${font_reset}"
                    echo "export PATH=\"\$PATH:$bin_path\"" >> "$install_path/.powerbashrc"
                fi
            done
        fi
    done

    # Specialized git configurations for .gitconfig file
    ConfigureGit

    # Specialized for ssh_tunnel service
    if [ $enable_ssh_tunnel_service -eq 1 ]; then
        ConfigureSSHTunnelService
    fi

    # check and append 'source .powerbashrc' statement
    PrintDebug "Ejecting powerbash runtime configuration ..."
    sed -i "/$source_comment_begin/,/$source_comment_end/d" "$bashrc_file"
    if [ -n "$(tail -n 1 "$bashrc_file")" ]; then echo "" >> "$bashrc_file"; fi
    {
        echo "$source_comment_begin"
        echo "source $install_path/.powerbashrc"
        echo "$source_comment_end"
    } >> "$bashrc_file"

    # remove temp files while install PowerBash from $install_archive
    if [ -n "$install_archive" ]; then rm -rf "$temp_dir"; fi

    # Generate vim help documents for new installed plugins
    PrintDebug "Generating help documents for vim plugins ..."
    if vim -h &> /dev/null; then
        vim -c 'Helptags' -c 'q' &> /dev/null
    fi

    # print character picture message
    echo -ne "${font_cyan}"
    echo " __________________          "
    echo "< Enjoy PowerBash! >         "
    echo " ------------------          "
    echo "        \   ^__^             "
    echo "         \  (oo)\_______     "
    echo "            (__)\       )\/\ "
    echo "                ||----w |    "
    echo "                ||     ||    "
    echo -e "${font_reset}"
}

function DoUninstall {
    # authority check for $uninstall_path
    PrintInfo "${font_magenta}Checking authority for uninstallation directory ...${font_reset}"
    if ! [ -r "$uninstall_path" ] || ! [ -w "$uninstall_path" ] || ! [ -x "$uninstall_path" ]; then
        PrintError "$uninstall_path not accessble, uninstall canceled!"
        exit 3
    fi

    # check PowerBash configuration
    PrintInfo "${font_magenta}Looking for existing configurations ...${font_reset}"
    local conf_list=
    local conf_index=0
    for file in "${files[@]}"; do
        if [ -f "$uninstall_path/$file" ]; then
            PrintInfo "${font_yellow}Found file $uninstall_path/$file${font_reset}"
            conf_list[conf_index]="$uninstall_path/$file"
            ((++conf_index))
        fi
    done
    for dir in "${dirs[@]}"; do
        if [ -d "$uninstall_path/$dir" ]; then
            PrintInfo "${font_yellow}Found directory $uninstall_path/$dir${font_reset}"
            conf_list[conf_index]="$uninstall_path/$dir"
            ((++conf_index))
        fi
    done

    # remove PowerBash configuration
    PrintInfo "${font_green}Start to uninstall PowerBash ...${font_reset}"
    rm -rf "${conf_list[@]}"

    # check and remove 'source .powerbashrc' statement
    PrintDebug "Removing powerbash runtime configuration ..."
    sed -i "/$source_comment_begin/,/$source_comment_end/d" "$bashrc_file"

    # print character picture message
    echo -ne "${font_cyan}"
    echo " ____________________        "
    echo "< Goodbye PowerBash! >       "
    echo " --------------------        "
    echo "        \   ^__^             "
    echo "         \  (xx)\_______     "
    echo "            (__)\       )\/\ "
    echo "                ||----w |    "
    echo "                ||     ||    "
    echo -e "${font_reset}"
}

# main body

## check options for PowerBash
if ! ParseArguments "$(basename "${BASH_SOURCE[0]}")" $sopt $lopt "$@"; then exit 1; fi
PrintDebug "Parsed arguments: $parsed_args"
eval set -- "$parsed_args"

## iterate options
while true; do
    case "$1" in
        "-i" | "--install")
            if [ -n "$2" ] && [ "${2:0:1}" == "-" ]; then
                install_path=$HOME
                shift 1
            else
                install_path=$2
                if [ -z "$install_path" ]; then install_path=$HOME; fi
                shift 2
            fi
        ;;
        "-u" | "--uninstall")
            if [ -n "$2" ] && [ "${2:0:1}" == "-" ]; then
                uninstall_path=$HOME
                shift 1
            else
                uninstall_path=$2
                if [ -z "$uninstall_path" ]; then uninstall_path=$HOME; fi
                shift 2
            fi
        ;;
        "-a" | "--archive")
            install_archive=$2
            shift 2
        ;;
        "--enable-ssh-tunnel-service")
            enable_ssh_tunnel_service=1
            shift 1
        ;;
        "-f" | "--force")
            install_force=1
            shift 1
        ;;
        "-h" | "--help")
            if [ $getopt_version = "enhanced" ]; then
                PrintHelp
            elif [ $getopt_version = "compatible" ]; then
                PrintHelpCompatible
            else
                PrintError "unrecognized getopt version string($getopt_version)!"
                exit 1
            fi
            exit 0
        ;;
        "--")
            if [ $# -gt 1 ]; then
                PrintError "unrecognized argument $2!"
                exit 1
            fi
            break
        ;;
        *)
            PrintError "unrecognized option $1!"
            exit 1
        ;;
    esac
done

## option confilict check
if [ -n "$uninstall_path" ]; then
    if [ -n "$install_path" ]; then
        PrintError "the install and uninstall options cannot specified at the same time!"
        exit 1
    elif [ -n "$install_archive" ]; then
        PrintError "the archive and uninstall options cannot specified at the same time!"
        exit 1
    elif [ $install_force -eq 1 ]; then
        PrintError "the force and uninstall options cannot specified at the same time!"
        exit 1
    fi
fi

if [ $enable_ssh_tunnel_service -eq 1 ]; then
    if [ -z "$install_path" ]; then
        PrintError "the --enable-ssh-tunnel-service option can only be specified with -i/--install!"
        exit 1
    elif [ -n "$install_archive" ]; then
        PrintError "the --enable-ssh-tunnel-service and -a/--archive options cannot specified " \
                   "at the same time!"
        exit 1
    fi
fi

## do options
enable_error_tracing

if [ -n "$install_path" ]; then DoInstall; fi
if [ -n "$uninstall_path" ]; then DoUninstall; fi

disable_error_tracing

